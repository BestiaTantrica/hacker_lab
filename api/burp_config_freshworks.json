{
  "target": {
    "scope": {
      "advanced_mode": true,
      "include": [
        {
          "enabled": true,
          "host": "^.*\\.freshworks\\.com$",
          "protocol": "any"
        },
        {
          "enabled": true,
          "host": "^.*\\.freshservice\\.com$",
          "protocol": "any"
        },
        {
          "enabled": true,
          "host": "^.*\\.freshdesk\\.com$",
          "protocol": "any"
        },
        {
          "enabled": true,
          "host": "^.*\\.freshchat\\.com$",
          "protocol": "any"
        },
        {
          "enabled": true,
          "host": "^.*\\.freshcaller\\.com$",
          "protocol": "any"
        },
        {
          "enabled": true,
          "host": "^.*\\.myfreshworks\\.com$",
          "protocol": "any"
        }
      ],
      "exclude": []
    }
  },
  "proxy": {
    "match_replace_rules": [
      {
        "comment": "Header obligatorio Freshworks Bug Bounty",
        "enabled": true,
        "is_simple_match": true,
        "match_string": "",
        "replace_string": "X-Bug-Bounty: HackerOne-tomas244",
