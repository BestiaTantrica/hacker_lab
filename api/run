#!/usr/bin/env bash
# run — Launcher de PEGASO
# Ejecutar desde cualquier directorio: ./run  o  bash LAB/api/run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PEGASO="${SCRIPT_DIR}/pegaso.py"
VENV="${SCRIPT_DIR}/venv"

# 1. Buscar Python: primero el venv local, luego el del OCI, luego el sistema
if [[ -x "${VENV}/bin/python3" ]]; then
    PYTHON="${VENV}/bin/python3"
elif [[ -x "/home/tomas2/workspace_lab/venv/bin/python3" ]]; then
    PYTHON="/home/tomas2/workspace_lab/venv/bin/python3"
else
    PYTHON="$(command -v python3 || command -v python)"
fi

# 2. Verificar que el script existe
if [[ ! -f "${PEGASO}" ]]; then
    echo "[ERROR] No se encontró ${PEGASO}" >&2
    exit 1
fi

# 3. Ejecutar desde el directorio del script para que .env y memoria se encuentren
cd "${SCRIPT_DIR}"
exec "${PYTHON}" "${PEGASO}" "$@"
